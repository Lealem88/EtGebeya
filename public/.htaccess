<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Do not rewrite requests for the backend API
  RewriteCond %{REQUEST_URI} ^/backend/ [NC]
  RewriteRule ^ - [L]

  # For React SPA routing: serve index.html for any request that is not an existing file or directory
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>
